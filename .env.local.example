# ============================================================
# Snowflake 設定
# ============================================================

# --- 接続情報 ---
SNOWFLAKE_ORGANIZATION=your_organization_name
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USERNAME=your_username
SNOWFLAKE_ROLE=your_role
SNOWFLAKE_WAREHOUSE=your_warehouse

# --- 認証方式 ---
# 使用する認証方式を指定します。
#   SNOWFLAKE_JWT          : キーペア (RSA) 認証。サーバー用途の推奨方式
#   SNOWFLAKE              : パスワード認証 (MFA 必須化されたアカウントでは利用不可)
#   USERNAME_PASSWORD_MFA  : パスワード+MFA キャッシュ。初回は対話必要
SNOWFLAKE_AUTHENTICATOR=SNOWFLAKE_JWT

# パスワード認証 (SNOWFLAKE / USERNAME_PASSWORD_MFA) の場合に使用
SNOWFLAKE_PASSWORD=your_password

# キーペア認証 (SNOWFLAKE_JWT) の場合に使用
#
# 暗号化なし鍵を生成する場合:
#   openssl genrsa 2048 | openssl pkcs8 -topk8 -inform PEM -out rsa_key.p8 -nocrypt
#   openssl rsa -in rsa_key.p8 -pubout -out rsa_key.pub
#
# パスフレーズ付き鍵を生成する場合 (推奨):
#   openssl genrsa 2048 | openssl pkcs8 -topk8 -inform PEM -out rsa_key.p8 -v2 aes-256-cbc
#   (パスフレーズが対話で求められる)
#   openssl rsa -in rsa_key.p8 -passin pass:YOUR_PASSPHRASE -pubout -out rsa_key.pub
#
# Snowflake 側で公開鍵を登録:
#   ALTER USER <username> SET RSA_PUBLIC_KEY='<rsa_key.pub の本体・改行除去>';
SNOWFLAKE_PRIVATE_KEY_PATH=/absolute/path/to/rsa_key.p8
# パスフレーズ付き鍵を使う場合のみ設定 (-nocrypt で生成した場合は空欄のまま)
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# --- 対象データベース・スキーマ ---
SNOWFLAKE_TARGET_DATABASE=YOUR_DATABASE_NAME

# カンマ区切りでスキーマの表示順（左から右）を指定します。
SNOWFLAKE_SCHEMA_ORDER=RAW,DWH,MART,PUBLIC

# --- ロール階層フィルタ ---
# ロール階層の取得モード。
#   by-objects (default) : SNOWFLAKE_TARGET_DATABASE / そのスキーマ群 /
#                          SNOWFLAKE_TARGET_WAREHOUSES に何らかの権限を
#                          持つロールと、その祖先ロールのみを取得します。
#   all                  : アカウント内の全ロールを取得します。
#   system-only          : ACCOUNTADMIN などの組み込みシステムロールのみ。
SNOWFLAKE_ROLE_FILTER_MODE=by-objects

# by-objects モードで対象とする WAREHOUSE をカンマ区切りで指定します。
# 未設定の場合は SNOWFLAKE_WAREHOUSE が単独で使用されます。
SNOWFLAKE_TARGET_WAREHOUSES=WH_DEV,WH_PIPELINE

# --- パフォーマンス ---
# Snowflake SDK のログイン・リトライタイムアウト (秒)。
# デフォルト 300。短くすると接続失敗時の待ち時間が減ります。
# SNOWFLAKE_RETRY_TIMEOUT=30

# ============================================================
# Terraform 設定
# ============================================================

# 描画対象となる Terraform プロジェクトのルートディレクトリ（絶対パス可）。
# カンマ区切りで複数パスを指定できます。
TERRAFORM_ROOT_PATH=your_terraform_path

# ============================================================
# Azure 設定
# ============================================================

# --- 共通認証 (Entra ID / ARM / Data Factory で共用) ---
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret

# --- Entra ID (Microsoft Graph API) ---
# Users / Groups / Apps の一覧を取得します。
# User.Read.All / Group.Read.All の管理者同意が必要です。
#
# 管理者同意が得られない環境ではスキップできます。
# AZURE_SKIP_ENTRA_ID=true

# --- Azure Resource Manager (ARM) ---
# Subscription / ResourceGroup / ACR / Batch / Data Factory を取得します。
# DefaultAzureCredential による認証が必要です。
#
# レート制限 (429) や権限不足で問題が出る場合はスキップできます。
# AZURE_SKIP_ARM=true

# --- Azure Blob Storage ---
# Azure Portal → ストレージ アカウント → アクセス キー → 接続文字列
AZURE_STORAGE_CONNECTION_STRING=your_connection_string

# --- Azure Data Factory (専用フェッチャ) ---
# ADF パイプライン / アクティビティ詳細を取得します。
# 上記の共通認証 (TENANT_ID / CLIENT_ID / CLIENT_SECRET) も必要です。
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_RESOURCE_GROUP=your_resource_group
AZURE_DATA_FACTORY_NAME=your_data_factory_name

# --- Azure DevOps ---
# Repos / Pipelines を取得します。
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-org
AZURE_DEVOPS_PAT=your_personal_access_token

# ============================================================
# パフォーマンス・チューニング (任意・デフォルト値あり)
# ============================================================

# --- 並列度 ---
# Azure DevOps の Project 並列フェッチ最大数 (デフォルト 8)
# AZURE_DEVOPS_MAX_PARALLEL=8

# ARM API の Subscription / Resource Group 並列フェッチ最大数 (デフォルト 8)
# AZURE_ARM_MAX_PARALLEL=8

# Blob Storage Container 並列リスト最大数 (デフォルト 8)
# AZURE_BLOB_MAX_PARALLEL=8

# Microsoft Graph (Entra ID) の users/groups/apps 1 ページあたり取得件数
# (最大 999 まで設定可能。デフォルト 100)
# AZURE_ENTRA_PAGE_SIZE=100

# --- リトライ / タイムアウト ---
# Azure ARM SDK のリトライ設定 (ResourceManagement, ContainerRegistry, Batch, DataFactory)
# AZURE_ARM_MAX_RETRIES=2              # デフォルト 3
# AZURE_ARM_RETRY_DELAY_MS=1000        # デフォルト 1000ms
# AZURE_ARM_MAX_RETRY_DELAY_MS=5000    # デフォルト 64000ms

# Entra ID (Microsoft Graph) fetch タイムアウト (ミリ秒)。デフォルト 10000ms。
# AZURE_ENTRA_TIMEOUT_MS=5000
