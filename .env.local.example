# Snowflake 接続情報
SNOWFLAKE_ORGANIZATION=your_organization_name
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USERNAME=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=your_role
SNOWFLAKE_WAREHOUSE=your_warehouse

# 取得対象のデータベース名 (先ほどのプランに基づく必須項目)
SNOWFLAKE_TARGET_DATABASE=YOUR_DATABASE_NAME

# ----------------------------------------
# Terraform Scanner Settings
# ----------------------------------------
# 描画対象となるTerraformプロジェクトのルートディレクトリ（絶対パス可）
TERRAFORM_ROOT_PATH=your_terraform_path

# ----------------------------------------
# Snowflake UI Settings
# ----------------------------------------
# カンマ区切りでスキーマの表示順（左から右）を指定します。
SNOWFLAKE_SCHEMA_ORDER=RAW,DWH,MART,PUBLIC

# ----------------------------------------
# Azure Settings
# ----------------------------------------
# Azure Blob Storage 接続文字列
AZURE_STORAGE_CONNECTION_STRING=your_connection_string

# Entra ID (Azure AD) Microsoft Graph API 取得用
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret

# Azure DevOps 設定
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-org
AZURE_DEVOPS_PAT=your_personal_access_token
